# ── Server ──────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# ── Recharge ────────────────────────────────────
RECHARGE_API_KEY=your_recharge_api_key_here

# ── Klaviyo ─────────────────────────────────────
KLAVIYO_API_KEY=pk_your_klaviyo_key_here

# ── CheckoutChamp ────────────────────────────────
CC_LOGIN_ID=your_cc_login_id
CC_API_PASSWORD=your_cc_api_password
CC_CLUB_ID=12

# ── Subi ─────────────────────────────────────────
SUBI_API_KEY=your_subi_api_key_here

# ── Admin dashboard ──────────────────────────────
# Postgres connection — Render adds this automatically
# when you attach a Postgres DB to the service.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Comma-separated list of emails allowed to sign in to /admin
ADMIN_EMAILS=nobel@eydigitalmedia.com

# Long random string for signing admin session tokens.
# Set this to a fresh value in production.
ADMIN_TOKEN_SECRET=change-me-to-a-long-random-string

# Set to "true" to skip the sync cron (useful for local dev)
SYNC_DISABLED=false
